{
  "name": "@currentspace/http3",
  "version": "0.5.0",
  "description": "HTTP/3 server and client for Node.js, powered by Cloudflare quiche",
  "author": "brianathere <brian@current.space>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/currentspace/http3.git"
  },
  "homepage": "https://github.com/currentspace/http3#readme",
  "bugs": {
    "url": "https://github.com/currentspace/http3/issues"
  },
  "keywords": [
    "http3",
    "quic",
    "http2",
    "nodejs",
    "napi",
    "quiche"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./fetch": {
      "types": "./dist/fetch-adapter.d.ts",
      "default": "./dist/fetch-adapter.js"
    },
    "./sse": {
      "types": "./dist/sse.d.ts",
      "default": "./dist/sse.js"
    },
    "./eventsource": {
      "types": "./dist/eventsource.d.ts",
      "default": "./dist/eventsource.js"
    },
    "./ops": {
      "types": "./dist/ops.d.ts",
      "default": "./dist/ops.js"
    },
    "./aws-cert": {
      "types": "./dist/aws-cert.d.ts",
      "default": "./dist/aws-cert.js"
    },
    "./express": {
      "types": "./dist/express-adapter.d.ts",
      "default": "./dist/express-adapter.js"
    },
    "./parity": {
      "types": "./dist/http2-parity.d.ts",
      "default": "./dist/http2-parity.js"
    },
    "./h3": {
      "types": "./dist/http3-extensions.d.ts",
      "default": "./dist/http3-extensions.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "LICENSE",
    "examples/certs/generate.sh",
    "examples/raw-api/README.md",
    "examples/raw-api/server.ts",
    "examples/raw-api/client.ts",
    "examples/express-adapter/README.md",
    "examples/express-adapter/package.json",
    "examples/express-adapter/adapter.ts",
    "examples/express-adapter/server.ts",
    "examples/hono/README.md",
    "examples/hono/package.json",
    "examples/hono/server.ts",
    "examples/hono/production-server.mjs",
    "examples/hono/production-server.ts",
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "napi": {
    "binaryName": "http3",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "aarch64-apple-darwin"
    ]
  },
  "scripts": {
    "build:dist": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc",
    "build": "napi build --platform --release && npm run build:dist",
    "build:debug": "napi build --platform && npm run build:dist",
    "build:test": "tsc -p tsconfig.test.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit",
    "lint": "eslint lib/ test/",
    "test:core": "npm run build:test && node --test --test-timeout=120000 dist-test/test/core/**/*.test.js",
    "test:runtime": "npm run build:test && node --test --test-timeout=120000 dist-test/test/runtime/**/*.test.js",
    "test:interop": "npm run build:test && node --test --test-timeout=120000 dist-test/test/interop/**/*.test.js",
    "test:release": "npm run build:test && node --test --test-timeout=120000 dist-test/test/release/**/*.test.js",
    "test:perf": "npm run build:test && node --test --test-timeout=120000 dist-test/test/perf-gates/**/*.test.js",
    "test": "npm run build:test && node --test --test-timeout=120000 dist-test/test/core/**/*.test.js dist-test/test/runtime/**/*.test.js dist-test/test/interop/**/*.test.js dist-test/test/release/**/*.test.js",
    "test:docker:runtime": "node scripts/docker-runtime-matrix.mjs",
    "test:docker:runtime:privileged": "HTTP3_RUNTIME_TEST_PRIVILEGED=1 node scripts/docker-runtime-matrix.mjs",
    "test:browser:e2e": "npm run build:test && HTTP3_BROWSER_E2E=1 node --test dist-test/test/browser/browser-e2e.test.js",
    "test:concurrency": "npm run build:test && node --test dist-test/test/perf-gates/worker-concurrency.test.js",
    "test:load-smoke": "npm run build:test && node --test dist-test/test/perf-gates/load-smoke.test.js",
    "test:rust:unit": "cargo test --lib --no-default-features",
    "test:rust:interop": "cargo test --test interop_udp_loopback && cargo test --test interop_quiche_direct",
    "test:rust:diagnostics": "cargo test --test transport_quiche_pair && cargo test --test release_curl_standalone",
    "test:rust": "npm run test:rust:unit && npm run test:rust:interop",
    "bench:h3": "npm run build:test && node scripts/h3-benchmark.mjs",
    "bench:h3:stress": "npm run build:test && node scripts/h3-benchmark.mjs --profile stress --allow-errors",
    "bench:h3:docker": "node scripts/docker-h3-benchmark.mjs",
    "bench:h3:docker:privileged": "node scripts/docker-h3-benchmark.mjs --include-privileged",
    "bench:quic": "npm run build:test && node scripts/quic-benchmark.mjs",
    "bench:quic:stress": "npm run build:test && node scripts/quic-benchmark.mjs --profile stress --allow-errors",
    "bench:quic:docker": "node scripts/docker-quic-benchmark.mjs",
    "bench:quic:docker:privileged": "node scripts/docker-quic-benchmark.mjs --include-privileged",
    "perf:linux:quic": "npm run build:test && node scripts/profile-linux-benchmark.mjs --protocol quic",
    "perf:linux:quic:direct": "node scripts/profile-rust-quic-direct.mjs",
    "perf:linux:quic:loopback": "node scripts/profile-rust-quic-loopback.mjs",
    "perf:node:quic:mock": "node scripts/profile-node-mock-transport.mjs",
    "perf:node:quic:mock:matrix": "node scripts/run-mock-bridge-matrix.mjs",
    "perf:linux:h3": "npm run build:test && node scripts/profile-linux-benchmark.mjs --protocol h3",
    "perf:macos:quic": "npm run build:test && node scripts/profile-macos-benchmark.mjs --protocol quic",
    "perf:macos:h3": "npm run build:test && node scripts/profile-macos-benchmark.mjs --protocol h3",
    "perf:analyze": "node scripts/analyze-perf-results.mjs",
    "perf:concurrency-gate": "npm run build:test && node scripts/concurrency-gate.mjs",
    "perf:load-smoke-gate": "npm run test:load-smoke",
    "smoke:install": "npm run build && node scripts/smoke-install.mjs",
    "safari:checklist": "node scripts/safari-validation-checklist.mjs",
    "sbom": "npm sbom --omit=dev > sbom.spdx.json",
    "release:check": "npm run lint && npm run typecheck && npm test && npm run test:browser:e2e && npm run perf:concurrency-gate && npm run perf:load-smoke-gate && npm run test:rust",
    "release:local-gate": "npm run release:check && npm run smoke:install",
    "release:publish:npm": "node scripts/publish-npm-release.mjs",
    "release:bootstrap:native": "node scripts/bootstrap-native-package.mjs",
    "release:latest": "node scripts/release-latest.mjs",
    "prepublishOnly": "npm run build:dist",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f http3",
    "load:curl:h3": "PROTO=h3 TOTAL=500 CONCURRENCY=50 bash scripts/load-curl-http.sh https://127.0.0.1:8443/",
    "load:curl:h2": "PROTO=h2 TOTAL=500 CONCURRENCY=50 bash scripts/load-curl-http.sh https://127.0.0.1:8443/",
    "load:rust:h3": "cargo run --release --manifest-path tools/rust-h3-load/Cargo.toml -- --addr 127.0.0.1:8443 --host localhost --path / --clients 10 --requests-per-client 20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@napi-rs/cli": "^3.0.0",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "playwright": "^1.55.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.1"
  },
  "optionalDependencies": {
    "@currentspace/http3-darwin-arm64": "0.5.0",
    "@currentspace/http3-linux-arm64-gnu": "0.5.0",
    "@currentspace/http3-linux-x64-gnu": "0.5.0"
  },
  "overrides": {
    "flatted": "^3.4.2"
  }
}
