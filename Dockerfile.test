FROM node:24-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
  ca-certificates \
  curl \
  build-essential \
  pkg-config \
  cmake \
  clang \
  perl \
  git \
  && rm -rf /var/lib/apt/lists/*

RUN curl https://sh.rustup.rs -sSf | sh -s -- -y --profile minimal --default-toolchain 1.85.0
ENV PATH="/root/.cargo/bin:${PATH}"

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm install --ignore-scripts

COPY build.rs Cargo.toml Cargo.lock ./
COPY src ./src
COPY lib ./lib
COPY test ./test
COPY index.js index.d.ts tsconfig.json tsconfig.test.json ./

RUN npm run build
RUN npx tsc -p tsconfig.test.json

# Run all stress + bench tests
CMD ["sh", "-c", "\
  echo '=== io_uring stress + bench tests ===' && \
  echo '--- quic-stress.test.js ---' && \
  node --test dist-test/test/interop/quic-stress.test.js && \
  echo '--- quic-driver-pressure.test.js ---' && \
  node --test dist-test/test/runtime/quic-driver-pressure.test.js && \
  echo '--- bench-compare.test.js ---' && \
  node --test dist-test/test/perf-gates/bench-compare.test.js && \
  echo '--- quic-bench-profile.test.js ---' && \
  node --test dist-test/test/perf-gates/quic-bench-profile.test.js && \
  echo '=== ALL TESTS PASSED ==='"]
